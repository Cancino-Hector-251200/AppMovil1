{
	"info": {
		"_postman_id": "clinica-api-collection",
		"name": "ClinicaApi",
		"description": "Colección completa de endpoints para ClinicaApi - Sistema de gestión de clínica médica.\n\nConfigura la variable {{base_url}} con la URL de tu servidor.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Health Check",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/",
							"host": ["{{base_url}}"],
							"path": [""]
						},
						"description": "Verifica que el servidor esté corriendo."
					},
					"response": []
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"correo\": \"usuario@ejemplo.com\",\n  \"password\": \"tu_password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						},
						"description": "Inicia sesión con correo y contraseña. Retorna el rol del usuario (DOCTOR o PACIENTE) y sus IDs correspondientes."
					},
					"response": []
				},
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"correo\": \"nuevo@ejemplo.com\",\n  \"password\": \"password_seguro\",\n  \"rol\": \"PACIENTE\",\n  \"nombre\": \"Juan Pérez\",\n  \"especialidad\": \"\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "Registra un nuevo usuario. Si el rol es DOCTOR, el campo 'especialidad' es obligatorio."
					},
					"response": []
				}
			]
		},
